# ───────────────────────── App ─────────────────────────
APP_NAME="Monitor Biomédico"
ENVIRONMENT=development            # development | production
# Orígenes permitidos para CORS (coma-separados). Incluye tu dominio de Cloudflare Pages.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost,https://*.pages.dev

# ──────────────────────── Base de datos ─────────────────
# Dev por defecto (SQLite, sin instalar nada):
DATABASE_URL=sqlite+aiosqlite:///./monitor_biomedico.db
# Producción (Postgres en el VPS o Supabase):
# DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/monitor_biomedico

# ───────────────────────── Seguridad ────────────────────
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200   # 30 días

# ───────────────────────── Groq (IA) ────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile        # alt: openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ──────────────────────── Resend (emails) ───────────────
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM="Monitor Biomédico <no-reply@tudominio.com>"

# ──────────────────────── Frontend ──────────────────────
# URL pública del frontend (para enlaces en emails de verificación, etc.)
FRONTEND_URL=http://localhost:8080
